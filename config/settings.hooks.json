{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Canonical hooks block. Merged into ~/.claude/settings.json by setup.sh/setup.ps1 via merge-hooks-settings.js. Edit here, not in installed settings.json -- local edits will be overwritten on next setup run.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/pre-bash-dev-server.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/pre-bash-tmux-suggest.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/pre-bash-git-push.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/context-guard.js"
          }
        ]
      },
      {
        "matcher": "Bash|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/pre-tool-taint-gate.js"
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Gmail__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/pre-tool-taint-gate.js"
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Google_Calendar__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/pre-tool-taint-gate.js"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_discord_discord__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/pre-tool-taint-gate.js"
          }
        ]
      },
      {
        "matcher": "mcp__email__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/pre-tool-taint-gate.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/session-start.js"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/session-start-mcp-scan.js"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/session-end-obsidian.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/pre-compact.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/post-bash-pr-log.js"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/post-edit-format.js"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/post-edit-typecheck.js"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/post-edit-console-warn.js"
          }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/post-tool-taint-source.js"
          }
        ]
      },
      {
        "matcher": "mcp__email__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/post-tool-taint-source.js"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_discord_discord__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/post-tool-taint-source.js"
          }
        ]
      },
      {
        "matcher": "mcp__.*(web.?search|web.?fetch|brave|tavily|exa).*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/post-tool-taint-source.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/hooks/check-console-log.js"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node $HOME/.claude/statusline.js"
  },
  "env": {
    "TAINT_GATE_DISABLE": "1"
  }
}
